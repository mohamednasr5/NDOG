{
  "rules": {
    "users": {
      ".read":  "auth != null",
      "$uid": {
        ".read":  "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        "balance":         { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "communityScore":  { ".validate": "newData.isNumber()" },
        "loyaltyScore":    { ".validate": "newData.isNumber()" },
        "totalReferrals":  { ".validate": "newData.isNumber()" },
        "deviceFingerprint": {
          ".write": "auth != null && auth.uid === $uid && !data.exists()"
        },
        "banned": {
          ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
        },
        "$other": { ".validate": false }
      },
      ".indexOn": ["balance", "communityScore", "country", "referralCode", "referredBy", "createdAt"]
    },

    "referrals": {
      ".read": "auth != null",
      "$refId": {
        ".read":  "auth != null && (data.child('referrer').val() === auth.uid || data.child('referredUser').val() === auth.uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && data.child('referredUser').val() === auth.uid && !data.exists()"
      },
      ".indexOn": ["referrer", "referredUser", "createdAt"]
    },

    "claims": {
      ".read": "auth != null",
      "$claimId": {
        ".read":  "auth != null && (data.child('userId').val() === auth.uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && data.child('userId').val() === auth.uid && newData.child('userId').val() === auth.uid",
        ".validate": "newData.hasChildren(['userId','amount','date'])",
        "amount": { ".validate": "newData.isNumber() && newData.val() > 0 && newData.val() < 1000" }
      },
      ".indexOn": ["userId", "date"]
    },

    "tasks": {
      ".read":  "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()",
      ".indexOn": ["status", "type", "period"]
    },

    "userTasks": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$taskId": {
          ".validate": "newData.hasChildren(['status','completedAt'])"
        }
      }
    },

    "notifications": {
      ".read":  "auth != null",
      "$nid": {
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
      }
    },

    "events": {
      ".read":  "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },

    "admins": {
      ".read":  "auth != null",
      ".write": "false"
    },

    "deviceFingerprints": {
      ".read":  "auth != null",
      "$fp": {
        ".write": "auth != null && (!data.exists() || data.val() === auth.uid)",
        ".validate": "newData.isString()"
      }
    },

    "flaggedAccounts": {
      ".read":  "auth != null && root.child('admins').child(auth.uid).exists()",
      ".write": "auth != null"
    },

    "stats": {
      ".read":  "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },

    "leaderboard": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },

    "bannedDevices": {
      ".read":  "auth != null && root.child('admins').child(auth.uid).exists()",
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    }
  }
}
