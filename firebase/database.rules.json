{
  "rules": {
    // ========== USERS ==========
    // Each user can read/write only their own profile.
    // Public can read limited fields (displayName, photoURL, country) for leaderboards.
    "users": {
      "$uid": {
        ".read": "auth.uid === $uid || root.child('admins/' + auth.uid).exists()",
        ".write": "
          // Self can write, but only safe fields (no balance/role tampering from client)
          (auth.uid === $uid && !data.exists()) ||
          (auth.uid === $uid && data.exists() &&
           !newData.hasChild('balance') &&
           !newData.hasChild('role') &&
           !newData.hasChild('banned') &&
           !newData.hasChild('founder') &&
           !newData.hasChild('vipLevel') &&
           !newData.hasChild('totalClaimed')) ||
          root.child('admins/' + auth.uid).exists()
        ",
        // Balance is writable only via admin or server-side (Cloud Functions in prod).
        // Client transactions (claim.js) use runTransaction which still requires write access.
        // To prevent tampering: enforce that balance can only INCREASE via legitimate operations.
        // In production, move all balance mutations to Cloud Functions.
        "balance": {
          ".write": "root.child('admins/' + auth.uid).exists() || (auth.uid === $uid && newData.val() >= data.val())",
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "role": {
          ".validate": "newData.isString() && (newData.val() === 'user' || newData.val() === 'mod' || newData.val() === 'admin')"
        },
        "email": { ".validate": "newData.isString() && newData.val().length < 256" },
        "displayName": { ".validate": "newData.isString() && newData.val().length < 80" },
        "referralCode": { ".validate": "newData.isString() && newData.val().matches(/^[A-Z0-9]{6,12}$/)" },
        "referredBy": { ".validate": "newData.isString() && newData.val().length < 50" }
      },
      // Allow reading only public-safe fields for leaderboards
      ".read": "auth != null"
    },

    // ========== ADMINS ==========
    // Only existing admins can read/write the admins list
    "admins": {
      ".read": "auth != null",
      "$uid": {
        ".write": "root.child('admins/' + auth.uid).exists()"
      }
    },

    // ========== BANNED USERS ==========
    "bannedUsers": {
      ".read": "auth != null",
      ".write": "root.child('admins/' + auth.uid).exists()"
    },

    // ========== CLAIMS ==========
    // User can create a claim record for themselves; everyone can read
    "claims": {
      ".read": "auth != null",
      "$claimId": {
        ".write": "auth.uid === newData.child('uid').val() || root.child('admins/' + auth.uid).exists()",
        ".validate": "
          newData.hasChild('uid') &&
          newData.hasChild('amount') &&
          newData.hasChild('ts') &&
          newData.child('amount').val() > 0 &&
          newData.child('amount').val() <= 10000
        "
      }
    },

    // ========== REFERRALS ==========
    // Referral records are created server-side (in auth flow). Users can read their own.
    "referrals": {
      "$uid": {
        ".read": "auth.uid === $uid || root.child('admins/' + auth.uid).exists()",
        ".write": "root.child('admins/' + auth.uid).exists()"
      }
    },

    // ========== REFERRAL CODES ==========
    // Anyone can read (to resolve a referral code → uid); writes only by admin/server
    "referralCodes": {
      ".read": "true",
      ".write": "root.child('admins/' + auth.uid).exists()"
    },

    // ========== MISSIONS ==========
    // Anyone authenticated can read missions; only admins can write
    "missions": {
      ".read": "auth != null",
      ".write": "root.child('admins/' + auth.uid).exists()"
    },

    "missionProgress": {
      "$uid": {
        ".read": "auth.uid === $uid || root.child('admins/' + auth.uid).exists()",
        // Allow user to mark own mission as complete (validation done client-side + via transactions)
        // In production: move to Cloud Functions for verification
        "$missionId": {
          ".write": "auth.uid === $uid || root.child('admins/' + auth.uid).exists()"
        }
      }
    },

    // ========== AIRDROPS ==========
    "airdrops": {
      ".read": "auth != null",
      ".write": "root.child('admins/' + auth.uid).exists()"
    },
    "airdropClaims": {
      "$uid": {
        ".read": "auth.uid === $uid || root.child('admins/' + auth.uid).exists()",
        "$taskId": {
          ".write": "auth.uid === $uid"
        }
      }
    },

    // ========== STAKING ==========
    "stakingContracts": {
      ".read": "auth != null",
      "$contractId": {
        ".write": "
          // User can create their own contract; admin can modify any
          (!data.exists() && newData.child('uid').val() === auth.uid) ||
          root.child('admins/' + auth.uid).exists()
        ",
        ".validate": "
          newData.hasChild('uid') &&
          newData.hasChild('amount') &&
          newData.child('amount').val() > 0
        "
      }
    },

    // ========== LEADERBOARDS ==========
    // Public read; write only via Cloud Functions (or trusted clients in MVP)
    // Note: For production, restrict writes to admin SDK only.
    "leaderboards": {
      ".read": "true",
      ".write": "auth != null && root.child('admins/' + auth.uid).exists()"
    },

    // ========== TRANSACTIONS ==========
    // Append-only log. User can write their own; everyone reads.
    "transactions": {
      ".read": "auth != null",
      "$txId": {
        ".write": "auth.uid === newData.child('uid').val() || root.child('admins/' + auth.uid).exists()",
        ".validate": "newData.hasChild('uid') && newData.hasChild('amount') && newData.hasChild('ts')"
      }
    },

    // ========== NOTIFICATIONS ==========
    // User reads only their own; admin can write to any user
    "notifications": {
      "$uid": {
        ".read": "auth.uid === $uid",
        "$notifId": {
          ".write": "auth.uid === $uid || root.child('admins/' + auth.uid).exists()"
        }
      }
    },

    // ========== NEWS ==========
    "news": {
      ".read": "true",
      ".write": "root.child('admins/' + auth.uid).exists()"
    },

    // ========== ANALYTICS ==========
    "analytics": {
      ".read": "root.child('admins/' + auth.uid).exists()",
      ".write": "auth != null"
    },

    // ========== FRAUD LOGS ==========
    // Anyone authenticated can write (client-side antifraud); only admins can read
    "fraudLogs": {
      ".read": "root.child('admins/' + auth.uid).exists()",
      "$logId": {
        ".write": "auth != null && newData.hasChild('type')"
      }
    },

    "adminAlerts": {
      ".read": "root.child('admins/' + auth.uid).exists()",
      ".write": "auth != null"
    },

    // ========== ADMIN AUDIT LOG ==========
    "adminAuditLog": {
      ".read": "root.child('admins/' + auth.uid).exists()",
      ".write": "root.child('admins/' + auth.uid).exists()"
    },

    // ========== DEVICES (fingerprint index) ==========
    // Readable by admins; writable by anyone authenticated (for registration)
    "devices": {
      ".read": "root.child('admins/' + auth.uid).exists()",
      "$fp": {
        ".write": "auth != null && (!data.exists() || data.child('uid').val() === auth.uid || root.child('admins/' + auth.uid).exists())"
      }
    },

    // ========== CONTACT MESSAGES ==========
    "contactMessages": {
      ".read": "root.child('admins/' + auth.uid).exists()",
      "$msgId": {
        ".write": "auth != null",
        ".validate": "newData.hasChild('email') && newData.hasChild('message')"
      }
    },

    // ========== WHEEL SPINS ==========
    "wheelSpins": {
      "$uid": {
        ".read": "auth.uid === $uid || root.child('admins/' + auth.uid).exists()",
        ".write": "auth.uid === $uid || root.child('admins/' + auth.uid).exists()"
      }
    },

    // ========== SESSIONS ==========
    "sessions": {
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth.uid === $uid"
      }
    }
  }
}
