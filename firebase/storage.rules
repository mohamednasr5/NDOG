rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ============ User Avatars ============
    // Users can upload their own avatar (max 2MB, image/* only)
    match /avatars/{uid}/{fileName} {
      allow read: if true;  // public read for avatars
      allow write: if request.auth.uid == uid
                   && request.resource.size < 2 * 1024 * 1024  // 2MB
                   && request.resource.contentType.matches('image/.*');

      // Allow user to overwrite their own avatar
      allow delete: if request.auth.uid == uid;
    }

    // ============ News Images ============
    // Only admins can upload news images (max 5MB)
    match /news/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid))
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ============ Public Assets ============
    match /public/{fileName} {
      allow read: if true;
      allow write: if false;  // uploads only via admin SDK
    }

    // ============ Mission Assets ============
    match /missions/{missionId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid))
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ============ KYC Documents (future) ============
    match /kyc/{uid}/{fileName} {
      allow read: if request.auth != null
                  && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
      allow write: if request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|application/pdf');
      allow delete: if request.auth.uid == uid;
    }

    // ============ Default Deny ============
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
