rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Public read for profile avatars ────────────────────
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && request.resource.contentType.matches('image/(jpeg|png|webp|gif)');
    }

    // ── News images: admin-only write, public read ─────────
    match /news/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|webp|gif|svg\\+xml)');
    }

    // ── Partner logos: admin-only write, public read ───────
    match /partners/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|webp|gif|svg\\+xml)');
    }

    // ── Badge icons: admin-only write, public read ─────────
    match /badges/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 512 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|webp|gif|svg\\+xml)');
    }

    // ── Screenshots for PWA manifest ───────────────────────
    match /screenshots/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    // ── Export files (admin data exports) ──────────────────
    match /exports/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && (request.resource.contentType.matches('application/json')
                       || request.resource.contentType.matches('text/csv'));
    }

    // ── Default: deny everything else ─────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
